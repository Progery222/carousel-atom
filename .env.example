# Copy to `.env` (not committed) and edit. Loaded by python-dotenv if you run
# `uvicorn` from a shell that has these vars exported.

# ── core ──────────────────────────────────────────────────────────────
CAROUSEL_LOG=INFO                 # DEBUG | INFO | WARNING
CAROUSEL_PRUNE_DAYS=180           # auto-prune seen-store at startup

# ── frontend / CORS ───────────────────────────────────────────────────
CAROUSEL_CORS=http://localhost:5173,http://127.0.0.1:5173

# ── public /api/v1 API ────────────────────────────────────────────────
# Comma-separated keys for the public API. Optional `name:key` form
# labels each key for logs and rate-limit buckets, e.g.
#   CAROUSEL_API_KEYS=internal:abc123,partner_acme:xyz789
# Leave empty to disable the public API (every /api/v1 call returns 503).
CAROUSEL_API_KEYS=
# Heavy-tier (render, export) rate limit per key per minute.
CAROUSEL_API_RATE_LIMIT=30/minute
# Light-tier (topics, designs, preview) rate limit per key per minute.
CAROUSEL_API_RATE_LIMIT_LIGHT=120/minute
# CORS origins for /api/v1 (default `*` — server-to-server). Set to a
# comma list of origins if you need to call /api/v1 from a browser app.
CAROUSEL_API_CORS=*
# Public origin (https://your-app.up.railway.app) used to build absolute
# URLs for slides in /api/v1 responses. Falls back to the request host
# when empty.
PUBLIC_BASE_URL=

# ── Telegram delivery (optional) ──────────────────────────────────────
# Topic-level chat IDs are referenced in topic.yaml as `env:CHAT_F1` etc.
TELEGRAM_BOT_TOKEN=
CHAT_F1=
CHAT_NBA=
CHAT_SOCCER=
CHAT_UFC=
CHAT_LIFESTYLE=

# ── LLM caption rewriter (optional) ───────────────────────────────────
# Any OpenAI-compatible endpoint works. Leave LLM_API_KEY empty to disable.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Image-search fallback (optional) ──────────────────────────────────
# When an article has no usable photo, the pipeline searches for a
# topical replacement. Wikimedia Commons works without any key. Pexels
# and Unsplash give broader coverage of generic news topics — both
# offer a free tier with no card required.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── NewsAPI source kind (optional) ────────────────────────────────────
NEWSAPI_KEY=
